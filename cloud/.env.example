# Set to "development" to enable uvicorn hot-reload (local dev only, not in Docker)
# ENV=development

# Database / cache
POSTGRES__URL=postgresql+asyncpg://postgres:postgres@localhost:5432/atto_cloud
# REDIS__URL=redis://localhost:6379/0

# Clerk — required
CLERK__SECRET_KEY=sk_test_<your-clerk-secret-key>

# Stripe — required keys (set empty string explicitly if disabled in local dev)
STRIPE__SECRET_KEY=
STRIPE__WEBHOOK_SECRET=
STRIPE__BASIC_PRICE_ID=
STRIPE__STANDARD_PRICE_ID=
STRIPE__PREMIUM_PRICE_ID=

# Provider settings (nested)
PROVIDERS__GLASSDOOR__API_KEY=
PROVIDERS__GLASSDOOR__BASE_URL=https://api.glassdoor.com/api/api.htm

PROVIDERS__SALARY__API_KEY=
PROVIDERS__SALARY__BASE_URL=https://api.salaryapi.com/v1/salary

PROVIDERS__MARKET__API_KEY=
PROVIDERS__MARKET__BASE_URL=https://newsapi.org/v2/everything

PROVIDERS__GEMINI__API_KEY=
PROVIDERS__GEMINI__BASE_URL=https://generativelanguage.googleapis.com
PROVIDERS__GEMINI__MODEL=gemini-3.1-flash-lite-preview
PROVIDERS__GEMINI__EMBEDDING_MODEL=gemini-embedding-001
PROVIDERS__GEMINI__TEMPERATURE=0.2

# Tuning (optional overrides)
# DEFAULT_TOKEN_BUDGET=1000
# QUEUE_TIMEOUT=30.0
