# Set to "development" to enable uvicorn hot-reload (local dev only, not in Docker)
# ENV=development

# Clerk — required
CLERK__JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
CLERK__ISSUER=https://<your-clerk-domain>
# CLERK__AUDIENCE=   # optional, set if your JWT includes an aud claim

# Provider API keys — leave empty to skip real calls during local testing
GLASSDOOR_API_KEY=
SALARY_API_KEY=
MARKET_API_KEY=

# PostgreSQL password (used by both postgres service and the api DSN)
# POSTGRES_PASSWORD=postgres   # default is fine for local dev

# Tuning (optional overrides)
# DEFAULT_TOKEN_BUDGET=1000
# WORKER_COUNT=2
# QUEUE_TIMEOUT=30.0
