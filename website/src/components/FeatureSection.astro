---
interface Feature {
  title: string;
  description: string;
  bullets: string[];
  image: string;
  imageAlt: string;
  label?: string;
}

interface Props {
  feature: Feature;
  reverse?: boolean;
}

const { feature, reverse = false } = Astro.props;
---

<section class:list={['section', 'feature', reverse && 'reverse']}>
  <div class="feature-copy">
    {feature.label && <p class="eyebrow">{feature.label}</p>}
    <h3>{feature.title}</h3>
    <p>{feature.description}</p>
    <ul>
      {feature.bullets.map((bullet) => (
        <li>{bullet}</li>
      ))}
    </ul>
  </div>

  <div class="feature-visual card">
    <img src={feature.image} alt={feature.imageAlt} loading="lazy" />
  </div>
</section>

<style>
  .feature {
    display: grid;
    gap: 1.25rem;
    align-items: center;
  }

  .feature h3 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin: 0.2rem 0 0.6rem;
  }

  .feature p {
    color: var(--muted-text);
    margin: 0;
  }

  .feature ul {
    margin: 0.75rem 0 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.45rem;
  }

  .feature-visual {
    padding: 0;
    overflow: hidden;
  }

  .feature-visual img {
    width: 100%;
    display: block;
    border-radius: 0.75rem;
  }

  @media (min-width: 900px) {
    .feature {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .feature.reverse .feature-copy {
      order: 2;
    }

    .feature.reverse .feature-visual {
      order: 1;
    }
  }
</style>
