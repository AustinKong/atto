---
import SectionCopy from "../shared/SectionCopy.astro";

interface Feature {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  label?: string;
}

interface Props {
  feature: Feature;
}

const { feature } = Astro.props;
---

<section class="section feature">
  <SectionCopy>
    {feature.label && <p class="eyebrow">{feature.label}</p>}
    <h2>{feature.title}</h2>
    <p>{feature.description}</p>
  </SectionCopy>

  <div class="screenshot-frame">
    <img src={feature.image} alt={feature.imageAlt} loading="lazy" />
  </div>
</section>

<style>
  .feature {
    display: grid;
    gap: clamp(1.6rem, 4vw, 3rem);
  }
</style>
