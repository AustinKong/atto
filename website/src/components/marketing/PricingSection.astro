---
const plans = [
  {
    name: 'Free',
    price: '$0',
    previousPrice: '',
    description: 'Everything you need to organize your job search.',
    featureIntro: 'Included',
    features: [
      'Save job listings',
      'Track applications',
      'Tailor resumes',
      'Local-first data storage',
      'Open-source'
    ]
  },
  {
    name: 'Pro',
    price: '$0',
    previousPrice: '$12/month',
    description: 'The same Atto, because core job-search features should not be gated.',
    featureIntro: 'Still included',
    features: [
      'AI job parsing',
      'Resume builder',
      'Application tracking',
      'No account required for local use',
      'Bring your own AI provider'
    ]
  },
  {
    name: 'Enterprise',
    price: 'Still $0',
    previousPrice: 'Contact sales',
    description: 'No sales calls. No procurement. Just an open-source tool you can use.',
    featureIntro: 'Also included',
    features: [
      'Open-source codebase',
      'Built in public',
      'Community feedback welcome',
      'No surprise upgrade prompts',
      'No locked features'
    ]
  }
] as const;
---

<section class="section pricing-section" id="pricing">
  <div class="section-copy">
    <p class="eyebrow">Pricing</p>
    <h2>Free means free.</h2>
    <p>
      Atto is free and open-source. No subscriptions, no locked features, no surprise upgrade
      prompts.
    </p>
  </div>

  <div class="pricing-grid">
    {
      plans.map((plan) => (
        <article class="pricing-card">
          <div class="pricing-card-header">
            <div>
              <h3>{plan.name}</h3>
              <p>{plan.description}</p>
            </div>
          </div>

          <div class="price-row">
            <span class="previous-price" aria-hidden={!plan.previousPrice ? 'true' : undefined}>
              {plan.previousPrice ? <s>{plan.previousPrice}</s> : <span>&nbsp;</span>}
            </span>
            <strong>{plan.price}</strong>
          </div>

          <div class="pricing-divider" />

          <p class="pricing-feature-intro">{plan.featureIntro}</p>
          <div class="pricing-features" role="list">
            {plan.features.map((feature) => (
              <div class="pricing-feature" role="listitem">
                <span class="pricing-check" aria-hidden="true" />
                <span>{feature}</span>
              </div>
            ))}
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .pricing-section {
    display: grid;
    gap: clamp(2rem, 4vw, 3.5rem);
  }

  .pricing-grid {
    display: grid;
    gap: 1rem;
  }

  .pricing-card {
    background: rgba(255, 255, 255, 0.56);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: clamp(1.4rem, 3vw, 2.4rem);
  }

  .pricing-card-header {
    display: block;
  }

  .pricing-card h3 {
    font-family: var(--font-body);
    font-size: clamp(1.35rem, 2.1vw, 1.75rem);
    line-height: 1.1;
  }

  .pricing-card p {
    font-size: clamp(1rem, 1.15vw, 1.125rem);
  }

  .price-row {
    display: grid;
    gap: 0.35rem;
    margin-top: clamp(2rem, 4vw, 3rem);
  }

  .previous-price {
    color: var(--muted-text);
    display: block;
    font-size: clamp(1rem, 1.2vw, 1.25rem);
    height: 1.5em;
    line-height: 1.5;
  }

  .price-row strong {
    color: var(--text);
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 4.8rem);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 0.95;
  }

  .pricing-divider {
    border-top: 1px solid var(--border);
    margin: clamp(1.8rem, 3vw, 2.5rem) 0 1.4rem;
  }

  .pricing-feature-intro {
    color: rgba(31, 31, 36, 0.52);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin: 0;
    text-transform: uppercase;
  }

  .pricing-features {
    display: grid;
    gap: 0.85rem;
    margin-top: 1.25rem;
  }

  .pricing-feature {
    align-items: center;
    color: var(--text);
    display: grid;
    font-size: clamp(1rem, 1.15vw, 1.125rem);
    gap: 0.75rem;
    grid-template-columns: auto 1fr;
    line-height: 1.25;
  }

  .pricing-check {
    border-bottom: 2px solid var(--brand-solid);
    border-left: 2px solid var(--brand-solid);
    display: block;
    height: 0.34rem;
    transform: rotate(-45deg) translateY(-1px);
    width: 0.62rem;
  }

  @media (min-width: 900px) {
    .pricing-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
