---
const primaryCtaHref = 'https://github.com/AustinKong/atto/releases';
const secondaryCtaHref = 'https://github.com/AustinKong/atto';
---

<section class="hero section" id="top">
  <div class="hero-copy">
    <p class="eyebrow">
      Local-first · Open-source · Built for job seekers applying to multiple roles
    </p>
    <h1>Organize your job search without spreadsheet chaos.</h1>
    <p class="subtitle">
      Track applications, tailor resumes, and keep your job search data on your device.
    </p>
    <div class="cta-row">
      <a class="atto-button atto-button-primary hero-primary-cta" href={primaryCtaHref}>
        Download Atto
      </a>
      <a
        class="atto-link-action hero-secondary-link"
        href={secondaryCtaHref}
        target="_blank"
        rel="noreferrer"
      >
        View on GitHub <span aria-hidden="true">-&gt;</span>
      </a>
    </div>
  </div>

  <div class="screenshot-frame">
    <img
      src="/screenshots/dummy-screenshot.png"
      alt="Atto dashboard showing saved jobs, application statuses, and resume tailoring"
      loading="eager"
    />
  </div>
</section>

<style>
  .hero {
    display: grid;
    gap: clamp(2.5rem, 6vw, 4.5rem);
    padding-top: clamp(4.5rem, 12vw, 10rem);
  }

  .hero-copy {
    max-width: 820px;
  }

  .hero-copy h1 {
    font-size: clamp(3.1rem, 6.2vw, 5.7rem);
    letter-spacing: 0;
    line-height: 0.96;
    margin: 1rem 0;
  }

  .subtitle {
    max-width: 66ch;
    margin: 0;
  }

  .cta-row {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .hero-primary-cta {
    min-height: 2.75rem;
    padding: 0 1.2rem;
  }

</style>
