---
import SectionCopy from "../shared/SectionCopy.astro";

const dataPoints = [
  {
    stat: "On-device",
    title: "Your data stays on your device",
    description:
      "We do not train on your data, we do not sell your data, and your data does not even leave your computer.",
  },
  {
    stat: "0% markup",
    title: "Bring your own API key",
    description:
      "Use the model provider you want. We add no markup, so you pay exactly for what you use.",
  },
  {
    stat: "Open-source",
    title: "No lock-in, no mystery",
    description:
      "Atto is open-source and built in public, so you can inspect, self-host, or fork at any time.",
  },
] as const;
---

<section class="section data-section" id="data">
  <SectionCopy>
    <p class="eyebrow">Data</p>
    <h2>Your job data stays yours.</h2>
    <p>Trust is a feature. Atto keeps data ownership simple and transparent.</p>
  </SectionCopy>

  <div class="data-grid" role="list">
    {
      dataPoints.map((point) => (
        <article class="data-card" role="listitem">
          <div class="data-stat">{point.stat}</div>
          <div class="data-copy">
            <h3>{point.title}</h3>
            <p>{point.description}</p>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .data-section {
    display: grid;
    gap: clamp(2rem, 4vw, 3rem);
  }

  .data-grid {
    display: grid;
    gap: 1.6rem;
  }

  .data-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    height: 100%;
    padding: 0;
  }

  .data-stat {
    align-items: flex-end;
    color: var(--brand-solid);
    display: flex;
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 5.4vw, 4.8rem);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1;
    min-height: calc(2 * 1em);
  }

  .data-copy {
    display: grid;
    gap: 0.5rem;
  }

  .data-card h3 {
    font-family: var(--font-body);
    font-size: clamp(1.25rem, 2.2vw, 1.5rem);
    margin: 0;
  }

  .data-card p {
    font-size: clamp(1rem, 1.15vw, 1.125rem);
    margin: 0;
  }

  @media (min-width: 900px) {
    .data-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
