---
interface Props {
  src: string;
  alt?: string;
  caption?: string;
  loading?: "lazy" | "eager";
}

const { src, alt = "", caption, loading = "lazy" } = Astro.props;
const isVideo = /\.(mp4|webm|mov)$/i.test(src);
---

<figure class="screenshot">
  <div
    class:list={["screenshot-frame", { "screenshot-frame--video": isVideo }]}
  >
    {
      isVideo ? (
        <video src={src} aria-label={alt} autoplay muted loop playsinline />
      ) : (
        <div class="screenshot-window">
          <img src={src} alt={alt} loading={loading} />
        </div>
      )
    }
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .screenshot {
    margin: 0;
    min-width: 0;
    width: 100%;
  }

  .screenshot-frame {
    aspect-ratio: 97 / 54;
    background: url("/macos-wallpaper.jpg") center / cover;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    display: grid;
    place-items: center;
    overflow: hidden;
    padding: 15% var(--screenshot-padding-inline);
    width: 100%;
  }

  .screenshot-frame--video {
    background: transparent;
    display: block;
    padding: 0;
  }

  .screenshot-frame--video video {
    border-radius: inherit;
    height: auto;
    max-width: 100%;
    object-fit: contain;
  }

  .screenshot-window {
    border: 1px solid var(--border);
    border-radius: 4px;
    height: auto;
    margin: 0 auto;
    overflow: hidden;
    width: auto;
  }

  .screenshot-frame img {
    display: block;
    height: auto;
    max-width: 100%;
    width: auto;
  }

  .screenshot-frame video {
    display: block;
    width: 100%;
  }

  .screenshot figcaption {
    margin-top: 0.65rem;
    color: var(--muted-text);
    font-size: var(--small-font-size);
    line-height: 1.35;
    text-align: center;
  }
</style>
