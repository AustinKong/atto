---
const primaryCtaHref = 'https://github.com/AustinKong/atto/releases';
const secondaryCtaHref = 'https://github.com/AustinKong/atto';
---

<section class="hero section" id="top">
  <div class="hero-copy">
    <p class="eyebrow">Atto job search tool</p>
    <h1>Organize your job search without spreadsheet chaos.</h1>
    <p class="subtitle">
      Track applications, tailor resumes, and keep your job search data on your device.
    </p>
    <div class="cta-row">
      <a class="btn btn-primary" href={primaryCtaHref}>Download Atto</a>
      <a class="btn btn-secondary" href={secondaryCtaHref} target="_blank" rel="noreferrer">View on GitHub</a>
    </div>
    <p class="trust-line">Local-first · Open-source · Built for job seekers applying to multiple roles</p>
  </div>

  <div class="hero-visual card">
    <img
      src="/screenshots/hero-overview.gif"
      alt="Atto dashboard showing saved jobs, application statuses, and resume tailoring"
      loading="eager"
    />
  </div>
</section>

<style>
  .hero {
    display: grid;
    gap: 1.5rem;
  }

  .hero-copy h1 {
    font-size: clamp(2rem, 5vw, 3.3rem);
    line-height: 1.1;
    margin: 0.5rem 0;
  }

  .subtitle {
    color: var(--muted-text);
    max-width: 60ch;
    font-size: 1.1rem;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .trust-line {
    margin-top: 1rem;
    color: var(--muted-text);
    font-size: 0.95rem;
  }

  .hero-visual {
    overflow: hidden;
    padding: 0;
  }

  .hero-visual img {
    width: 100%;
    display: block;
    border-radius: 0.75rem;
  }

  @media (min-width: 900px) {
    .hero {
      grid-template-columns: 1.1fr 1fr;
      align-items: center;
    }
  }
</style>
