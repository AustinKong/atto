---
import FeatureSection from "../components/marketing/FeatureSection.astro";
import HeroSection from "../components/marketing/HeroSection.astro";
import JobDataSection from "../components/marketing/JobDataSection.astro";
import PricingSection from "../components/marketing/PricingSection.astro";
import SocialProofSection from "../components/marketing/SocialProofSection.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const features = [
  {
    label: "Less copy-pasting",
    title: "Save jobs in seconds.",
    description:
      "Found a role you like? Paste the job URL and Atto pulls the key details into a clean summary — no more jumping between tabs just to copy company names, requirements, and role descriptions.",
    image: "/marketing/job-save.mp4",
    imageAlt:
      "User pastes a job URL into Atto, reviews the parsed job details in an editor, saves the listing, and is redirected to the saved jobs list.",
  },
  {
    label: "No more guessing",
    title: "Track every application.",
    description:
      "Know exactly where each opportunity stands. Atto helps you track what you saved, applied to, interviewed for, or need to follow up on, so your next step is always clear.",
    image: "/marketing/listings-select.mp4",
    imageAlt:
      "User opens a saved job from the listings page, reviews the job details side panel, generates research analysis, then switches to the application tab to view the application status.",
  },
  {
    label: "Beat the ATS",
    title: "Tailor resumes for each role.",
    description:
      "Stop sending the same resume everywhere. Atto uses the job description and your existing resume to generate a role-specific version automatically.",
    image: "/marketing/resume-editor.mp4",
    imageAlt:
      "User opens a resume from a saved application, reviews the generated resume in a dual-pane editor, then opens the resume analysis page and toggles analysis results.",
  },
] as const;
---

<BaseLayout
  title="Atto — Organize your job search"
  description="A local-first, open-source AI tool that helps job seekers track applications and tailor resumes."
>
  <HeroSection />
  <SocialProofSection />

  {features.map((feature) => <FeatureSection feature={feature} />)}

  <JobDataSection />
  <PricingSection />
</BaseLayout>
