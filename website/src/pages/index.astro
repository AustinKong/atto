---
import FeatureSection from '../components/FeatureSection.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import LocalFirstNote from '../components/LocalFirstNote.astro';
import SocialProofMarquee from '../components/SocialProofMarquee.astro';
import { features, offerCompanies } from '../constants/marketing-data';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Atto — Organize your job search"
  description="A local-first, open-source AI tool that helps job seekers track applications and tailor resumes."
>
  <HeroSection />
  <SocialProofMarquee companies={offerCompanies} />

  <section class="section">
    <p class="eyebrow">Features</p>
    <h2>Everything you need to manage your search.</h2>
    <p class="section-subheadline">
      Save jobs, track progress, and tailor resumes without jumping between spreadsheets, tabs, and
      documents.
    </p>
  </section>

  {features.map((feature, index) => <FeatureSection feature={feature} reverse={index % 2 === 1} />)}

  <LocalFirstNote />
  <FinalCTA />
  <Footer />
</BaseLayout>

<style>
  .section-subheadline {
    margin: 0.6rem 0 0;
    color: var(--muted-text);
    max-width: 68ch;
  }
</style>
