---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Atto — Job application tracker" description="Track jobs, tailor resumes, and stay organized with Atto.">
  <section class="card">
    <h1>Organize every job application with Atto</h1>
    <p>
      Atto is a local-first tool that helps you track roles, tailor application materials, and keep your
      job search moving.
    </p>
    <ul>
      <li>Track applications by stage</li>
      <li>Customize resumes and cover letters quickly</li>
      <li>Keep all your job search context in one place</li>
    </ul>
    <p><a href="/blog">Read the blog →</a></p>
  </section>
</BaseLayout>
