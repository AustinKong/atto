---
import Footer from "../components/layout/Footer.astro";
import FeatureSection from "../components/marketing/FeatureSection.astro";
import HeroSection from "../components/marketing/HeroSection.astro";
import JobDataSection from "../components/marketing/JobDataSection.astro";
import PricingSection from "../components/marketing/PricingSection.astro";
import SocialProofMarquee from "../components/marketing/SocialProofMarquee.astro";
import SectionCopy from "../components/shared/SectionCopy.astro";
import { features, offerCompanies } from "../constants/marketing-data";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Atto — Organize your job search"
  description="A local-first, open-source AI tool that helps job seekers track applications and tailor resumes."
>
  <HeroSection />
  <SocialProofMarquee companies={offerCompanies} />

  <SectionCopy as="section" class="section">
    <p class="eyebrow">Features</p>
    <h2>Everything you need to manage your search.</h2>
    <p>
      Save jobs, track progress, and tailor resumes without jumping between
      spreadsheets, tabs, and documents.
    </p>
  </SectionCopy>

  {features.map((feature) => <FeatureSection feature={feature} />)}

  <JobDataSection />
  <PricingSection />
  <Footer />
</BaseLayout>
