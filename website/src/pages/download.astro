---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { Code } from 'astro-expressive-code/components';
import Button from '../components/shared/Button.astro';
import { getDownloadCount } from '../lib/github';

export const prerender = false;

const downloadCount = await getDownloadCount();

const downloads = {
  windows:
    'https://github.com/austinkong/atto/releases/latest/download/atto-windows.exe',
  macos:
    'https://github.com/austinkong/atto/releases/latest/download/atto-macos.dmg',
  linux:
    'https://github.com/austinkong/atto/releases/latest/download/atto-linux.tar.gz',
};
---

<BaseLayout
  title="Download Atto"
  description="Install Atto locally on your device to seamlessly organize your job search."
>
  <div class="download-page">
    <div class="content-max-width">
      <p class="caption">Join {downloadCount.toLocaleString()} other job seekers</p>
      <h1>Install Atto</h1>
      <p>
        Atto is distributed as a Python package. We recommend using pipx to
        install it globally on your system in an isolated environment.
      </p>
      <div class="install-command">
        <Code code="pipx install atto" lang="bash" />
      </div>
    </div>

    <div class="or-divider content-max-width">
      <span class="caption">OR</span>
    </div>

    <div class="content-max-width">
      <div class="download-button-group">
        <Button
          href={downloads.windows}
          variant="secondary"
          data-os="windows"
          download
        >
          <Icon name="simple-icons:windows" aria-hidden="true" />
          Download for Windows
        </Button>
        <Button
          href={downloads.macos}
          variant="secondary"
          data-os="mac"
          download
        >
          <Icon name="simple-icons:apple" aria-hidden="true" />
          Download for macOS
        </Button>
        <Button
          href={downloads.linux}
          variant="secondary"
          data-os="linux"
          download
        >
          <Icon name="simple-icons:linux" aria-hidden="true" />
          Download for Linux
        </Button>
      </div>
      <p>
        Atto is currently distributed as an independent build and may trigger
        operating system security warnings until code signing and notarization
        are available. <a
          href="https://github.com/AustinKong/atto/blob/main/setup.md"
          target="_blank"
          rel="noreferrer">Check out the setup guide for more details.</a
        >
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  const platform =
    // @ts-ignore
    navigator.userAgentData?.platform?.toLowerCase?.() ??
    navigator.platform?.toLowerCase?.() ??
    "";

  const buttons = document.querySelectorAll("[data-os]");

  buttons.forEach((button) => {
    const os = button.getAttribute("data-os")?.toLowerCase();

    if (!os) return;

    if (platform.includes(os)) {
      button.classList.remove("secondary");
      button.classList.add("primary");
    }
  });
</script>

<style>
  .install-command {
    margin-top: 1.5rem;
  }

  .or-divider {
    display: flex;
    align-items: center;
    margin: 2.5rem 0;
  }

  .or-divider::before,
  .or-divider::after {
    content: "";
    flex: 1;
    border-bottom: 2px solid var(--border);
  }

  .or-divider::before {
    margin-right: 1.5rem;
  }

  .or-divider::after {
    margin-left: 1.5rem;
  }

  .download-button-group {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  @media (max-width: 47.99rem) {
    .download-button-group {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>
