---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/layout/Footer.astro";
import CommandBlock from "../components/shared/CommandBlock.astro";
import SectionCopy from "../components/shared/SectionCopy.astro";
import { Icon } from "astro-icon/components";
---

<BaseLayout
  title="Download Atto"
  description="Install Atto locally on your device to seamlessly organize your job search."
>
  <main class="download-page">
    <SectionCopy as="section" class="section">
      <p class="eyebrow">Download</p>
      <h1>Install Atto</h1>

      <div class="install-pipx">
        <p>
          Atto is distributed as a Python package. We recommend using pipx to
          install it globally on your system in an isolated environment.
        </p>

        <CommandBlock command="pipx install atto" />
      </div>

      <div class="or-divider">
        <span class="eyebrow">OR</span>
      </div>

      <div class="download-primary">
        <div class="download-button-group">
          <a
            href="https://github.com/AustinKong/atto/releases"
            class="atto-button atto-button-secondary os-btn"
            data-os="Windows"
          >
            <Icon
              class="os-icon"
              name="simple-icons:windows"
              aria-hidden="true"
            />
            Download for Windows
          </a>
          <a
            href="https://github.com/AustinKong/atto/releases"
            class="atto-button atto-button-secondary os-btn"
            data-os="macOS"
          >
            <Icon
              class="os-icon"
              name="simple-icons:apple"
              aria-hidden="true"
            />
            Download for macOS
          </a>
          <a
            href="https://github.com/AustinKong/atto/releases"
            class="atto-button atto-button-secondary os-btn"
            data-os="Linux"
          >
            <Icon
              class="os-icon"
              name="simple-icons:linux"
              aria-hidden="true"
            />
            Download for Linux
          </a>
        </div>
        <p class="security-warning">
          Atto is currently distributed as an independent build and may trigger
          operating system security warnings until code signing and notarization
          are available. <a
            href="https://github.com/AustinKong/atto/blob/main/setup.md"
            target="_blank"
            rel="noreferrer"
            style="text-decoration: underline;"
            >Check out the setup guide for more details.</a
          >
        </p>
      </div>
    </SectionCopy>
  </main>

  <Footer />
</BaseLayout>

<script>
  let platform = "";

  // @ts-ignore - navigator.userAgentData is a relatively new API not in all TS targets yet
  if (navigator.userAgentData && navigator.userAgentData.platform) {
    platform = navigator.userAgentData.platform;
  } else {
    const fallbackPlat = navigator.platform.toLowerCase();
    if (fallbackPlat.includes("mac")) platform = "macOS";
    else if (fallbackPlat.includes("win")) platform = "Windows";
    else if (fallbackPlat.includes("linux")) platform = "Linux";
  }

  const btns = document.querySelectorAll(".os-btn");
  btns.forEach((btn) => {
    const os = btn.getAttribute("data-os");
    if (platform && os && platform.toLowerCase().includes(os.toLowerCase())) {
      btn.classList.remove("atto-button-secondary");
      btn.classList.add("atto-button-primary");
    }
  });
</script>

<style>
  .download-page {
    /* Mimic hero section top padding so it looks consistent out of the gate */
    padding-top: clamp(4.5rem, 12vw, 10rem);
    min-height: 80vh;
  }

  h1 {
    font-size: clamp(3.1rem, 6.2vw, 5.7rem);
    letter-spacing: 0;
    line-height: 0.96;
    margin: 1rem 0;
  }

  .install-pipx {
    margin: 2.5rem 0;
  }

  .or-divider {
    display: flex;
    align-items: center;
    margin: 3.5rem 0;
    max-width: 480px;
  }

  .or-divider::before,
  .or-divider::after {
    content: "";
    flex: 1;
    border-bottom: 1px solid var(--border, #e5e7eb);
  }

  .or-divider::before {
    margin-right: 1.5rem;
  }

  .or-divider::after {
    margin-left: 1.5rem;
  }

  .download-primary {
    margin: 3rem 0;
  }

  .download-button-group {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .os-btn {
    min-height: 3.2rem;
    padding: 0 1.5rem;
    font-size: 1.1rem;
    gap: 0.6rem;
  }

  .os-icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  .security-warning {
    margin-top: 1.25rem;
    max-width: 65ch;
  }
</style>
