---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { Code } from "astro-expressive-code/components";
import Button from "../components/shared/Button.astro";

const downloads = {
  windows:
    "https://github.com/austinkong/atto/releases/latest/download/atto-windows.exe",
  macos:
    "https://github.com/austinkong/atto/releases/latest/download/atto-macos.dmg",
  linux:
    "https://github.com/austinkong/atto/releases/latest/download/atto-linux.tar.gz",
};

const installCommand = `
# Install Atto
pip install atto-app
# Launch Atto
atto
`;
---

<BaseLayout
  title="Download Atto"
  description="Install Atto locally on your device to seamlessly organize your job search."
>
  <div class="download-page">
    <div class="content-max-width">
      <p class="caption" id="download-count-caption">Join other job seekers</p>
      <h1>Download Atto</h1>
      <p>
        Atto is distributed as a Python package, we <strong>strongly</strong> recommend
        installing this way if you already have Python on your system, it's just less
        hassle. Install it with pip, then run the local app from your terminal.
      </p>
      <div class="install-command">
        <Code code={installCommand} lang="bash" />
      </div>
    </div>

    <div class="or-divider content-max-width">
      <span class="caption">OR</span>
    </div>

    <div class="content-max-width">
      <div class="download-button-group">
        <Button
          href={downloads.windows}
          variant="secondary"
          data-os="windows"
          download
        >
          <Icon name="simple-icons:windows" aria-hidden="true" />
          Download for Windows
        </Button>
        <Button
          href={downloads.macos}
          variant="secondary"
          data-os="mac"
          download
        >
          <Icon name="simple-icons:apple" aria-hidden="true" />
          Download for macOS
        </Button>
        <Button
          href={downloads.linux}
          variant="secondary"
          data-os="linux"
          download
        >
          <Icon name="simple-icons:linux" aria-hidden="true" />
          Download for Linux
        </Button>
      </div>
      <p>
        Atto is currently distributed as an independent build and may trigger
        operating system security warnings until code signing and notarization
        are available. <a
          href="https://github.com/AustinKong/atto/blob/main/docs/installation.md"
          target="_blank"
          rel="noreferrer">Check out the installation guide for more details.</a
        >
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  const platform =
    // @ts-ignore
    navigator.userAgentData?.platform?.toLowerCase?.() ??
    navigator.platform?.toLowerCase?.() ??
    "";

  const buttons = document.querySelectorAll("[data-os]");

  buttons.forEach((button) => {
    const os = button.getAttribute("data-os")?.toLowerCase();

    if (!os) return;

    if (platform.includes(os)) {
      button.classList.remove("secondary");
      button.classList.add("primary");
    }
  });

  const downloadCountCaption = document.querySelector(
    "#download-count-caption",
  );

  fetch("/api/download-count")
    .then((response) => (response.ok ? response.text() : "0"))
    .then((text) => {
      const downloads = Number(text);

      if (downloadCountCaption && downloads > 0) {
        downloadCountCaption.textContent = `Join ${downloads.toLocaleString()} other job seekers`;
      }
    })
    .catch(() => {
      // Keep the static fallback caption.
    });
</script>

<style>
  .install-command {
    margin-top: 1.5rem;
  }

  .or-divider {
    display: flex;
    align-items: center;
    margin: 2.5rem 0;
  }

  .or-divider::before,
  .or-divider::after {
    content: "";
    flex: 1;
    border-bottom: 2px solid var(--border);
  }

  .or-divider::before {
    margin-right: 1.5rem;
  }

  .or-divider::after {
    margin-left: 1.5rem;
  }

  .download-button-group {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  @media (max-width: 47.99rem) {
    .download-button-group {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>
